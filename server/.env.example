# Copiez ce fichier en .env et adaptez les valeurs.

# API
PORT=3001

# Version exposée sur GET /api/health (optionnel)
APP_VERSION=1.0.0

# Limitation de débit (requêtes / fenêtre de 15 min par IP)
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_AUTH_MAX=30

# MySQL (même machine : localhost)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=votre_mot_de_passe
DB_NAME=smallworld

# Origine autorisée pour CORS (production). Laisser vide ou * pour tout autoriser en dev.
# Exemple : http://localhost:8080
CORS_ORIGIN=

# JWT — changez en production (chaîne longue et aléatoire)
JWT_SECRET=changez-moi-en-production-avec-une-longue-chaine-aleatoire

# Mot de passe du compte admin créé par npm run seed:admin (optionnel)
SEED_ADMIN_PASSWORD=Admin123!
